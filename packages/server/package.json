{
  "name": "@deck-monsters/server",
  "version": "0.1.0",
  "description": "Deck Monsters API server — Fastify + tRPC + Drizzle",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc --build",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@deck-monsters/engine": "workspace:*",
    "@fastify/websocket": "^11.0.2",
    "@trpc/server": "^11.4.3",
    "drizzle-orm": "^0.44.2",
    "fastify": "^5.4.0",
    "jose": "^5.10.0",
    "pg": "^8.16.3",
    "zod": "^3.25.71"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/pg": "^8.11.15",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.0.0",
    "typescript": "^5.9.3"
  }
}
