# Multi-stage build for the Deck Monsters web app (@deck-monsters/web)
# Runs on Railway as the static SPA service.

# ── Stage 1: Install dependencies ──────────────────────────────────────────
FROM node:22-alpine AS deps

WORKDIR /app

RUN corepack enable pnpm

# Copy all workspace manifests so pnpm can resolve the full workspace graph
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY apps/web/package.json                        ./apps/web/package.json
COPY packages/engine/package.json                 ./packages/engine/package.json
COPY packages/server/package.json                 ./packages/server/package.json
COPY packages/connector-discord/package.json      ./packages/connector-discord/package.json

RUN pnpm install --frozen-lockfile


# ── Stage 2: Build ─────────────────────────────────────────────────────────
FROM deps AS builder

WORKDIR /app

# Engine source — must be compiled first so its dist/ declarations are
# available when the server (and transitively the web app) resolves types.
COPY packages/engine ./packages/engine
RUN pnpm --filter @deck-monsters/engine build

# Server source — web app imports tRPC types from @deck-monsters/server/src
COPY packages/server ./packages/server

# Web app source
COPY apps/web ./apps/web
RUN pnpm --filter @deck-monsters/web build


# ── Stage 3: Production image ───────────────────────────────────────────────
FROM node:22-alpine AS runner

WORKDIR /app

# Install serve globally — minimal runtime, no workspace needed
RUN npm install -g serve

COPY --from=builder /app/apps/web/dist ./dist

EXPOSE 3000

ENV NODE_ENV=production

CMD ["serve", "dist", "--listen", "3000"]
