# Copy to .env.local and fill in values

# Supabase project URL and Publishable key (from Supabase dashboard → Settings → API → Publishable and secret API keys)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# API server URL (leave empty in development to use the Vite proxy)
# In production, set to your Railway deployment URL
VITE_SERVER_URL=
