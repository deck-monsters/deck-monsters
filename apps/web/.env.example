# Copy to .env.local and fill in values

# Supabase project URL and Publishable key
# Found at: Supabase dashboard → Settings → API Keys → Publishable key
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# API server URL (leave empty in development to use the Vite proxy)
# In production, set to your Railway deployment URL
VITE_SERVER_URL=
