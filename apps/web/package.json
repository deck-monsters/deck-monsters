{
  "name": "@deck-monsters/web",
  "version": "0.1.0",
  "description": "Deck Monsters web client — two-pane terminal rebuild",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "start": "serve dist -s -l tcp://0.0.0.0:${PORT:-3000}",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@deck-monsters/engine": "workspace:*",
    "@deck-monsters/server": "workspace:*",
    "@fontsource/jetbrains-mono": "^5.2.5",
    "@fontsource/press-start-2p": "^5.2.7",
    "@supabase/supabase-js": "^2.49.4",
    "@tanstack/react-query": "^5.64.2",
    "@trpc/client": "^11.4.3",
    "@trpc/react-query": "^11.4.3",
    "@trpc/server": "^11.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "serve": "^14.2.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.21",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.4.1",
    "jsdom": "^26.1.0",
    "typescript": "^5.9.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.1"
  }
}
