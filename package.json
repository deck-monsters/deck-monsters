{
  "name": "deck-monsters",
  "description": "Spawn monsters, equip them with cards, and send them into the ring to fight.",
  "version": "0.13.1",
  "packageManager": "pnpm@10.33.0",
  "contributors": [
    {
      "name": "David Brainer",
      "email": "david@brainermail.com"
    },
    {
      "name": "Christopher McCulloh"
    }
  ],
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "supabase"
    ]
  },
  "scripts": {
    "build:docs": "node --import ./packages/engine/node_modules/tsx/dist/esm/index.cjs ./build/index.js",
    "build": "turbo run build",
    "dev": "turbo run build --watch",
    "lint:fix": "turbo run lint:fix",
    "lint": "turbo run lint",
    "test:watch": "cd packages/engine && npm run test:watch",
    "test:coverage": "cd packages/engine && npm run test:coverage",
    "test": "turbo run test",
    "setup:local": "bash scripts/setup-local.sh"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:deck-monsters/deck-monsters.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@types/node": "^24.6.0",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "supabase": "^2.84.10",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3"
  }
}
